{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Easy Infer Station",
  "version": "0.0.2",
  "identifier": "com.easyolo.infer-station",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Easy Infer Station",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../app.py",
      "../config.py",
      "../requirements.txt",
      "../.env.example",
      "../routes",
      "../services",
      "../static",
      "../models"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
